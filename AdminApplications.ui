  <property name="styleSheet">
   <string notr="true">
QMainWindow { background-color: #fef9e7; }


/* GENEL BUTON AYARLARI */
QPushButton {
    border-radius: 10px;
    font-weight: bold;
    font-size: 13px;
    color: white;
    padding: 5px;
}

/* 1. ARAMA VE FİLTRELER (Mavi Tonları) */
QPushButton#buttonAra, QPushButton#buttonBasvuru {
    background-color: #2980b9;
}
QPushButton#buttonAra:hover, QPushButton#buttonBasvuru:hover {
    background-color: #3498db;
}

/* 2. GÖRÜŞME KAYITLARI (Yeşil Tonları) */
QPushButton#buttonTanimlanan, QPushButton#buttonTanimlanmayan {
    background-color: #27ae60;
}
QPushButton#buttonTanimlanan:hover, QPushButton#buttonTanimlanmayan:hover {
    background-color: #2ecc71;
}

/* 3. KAYIT SORGULAMA (Mor Tonları) */
QPushButton#buttonOncekiVit, QPushButton#tumBasvurularGetir {
    background-color: #8e44ad;
}
QPushButton#buttonOncekiVit:hover, QPushButton#tumBasvurularGetir:hover {
    background-color: #9b59b6;
}

/* 4. KAYIT DURUMLARI (Turuncu Tonları) */
QPushButton#buttonMukkerrer, QPushButton#buttonFarkli {
    background-color: #d35400;
}
QPushButton#buttonMukkerrer:hover, QPushButton#buttonFarkli:hover {
    background-color: #e67e22;
}

/* 5. TERCİHLER (Sarı/Altın Tonları) */
QPushButton#buttonTercihler {
    background-color: #f39c12;
}
QPushButton#buttonTercihler:hover {
    background-color: #f1c40f;
}

/* 6. EXIT (Kırmızı Tonları) */
QPushButton#buttonExit {
    background-color: #c0392b;
}
QPushButton#buttonExit:hover {
    background-color: #e74c3c;
}</string>
